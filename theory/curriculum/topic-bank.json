{
  "learner_level": "strict_progressive",
  "domains": ["cs", "network", "cs-network-applied"],
  "topics": [
    {
      "id": "program-process-thread-basics",
      "level": 0,
      "domain": "cs",
      "title": "프로그램, 프로세스, 스레드의 경계",
      "prerequisites": [],
      "builds_on": [],
      "subtopics": ["program", "process", "thread", "address space", "execution context"],
      "real_work_application": "서버가 떠 있는데 요청 처리가 멈추는 상황, CPU 사용률이 높은 상황, 동시성 문제를 구분해서 진단한다."
    },
    {
      "id": "memory-stack-heap-basics",
      "level": 0,
      "domain": "cs",
      "title": "메모리, 스택, 힙의 실무적 의미",
      "prerequisites": ["program-process-thread-basics"],
      "builds_on": ["program-process-thread-basics"],
      "subtopics": ["memory", "stack", "heap", "allocation", "lifetime"],
      "real_work_application": "메모리 누수, 큰 객체 할당, 재귀/콜스택 문제를 설명하고 장애 원인을 좁힌다."
    },
    {
      "id": "cpu-scheduling-basics",
      "level": 1,
      "domain": "cs",
      "title": "CPU 스케줄링과 컨텍스트 스위칭",
      "prerequisites": ["program-process-thread-basics"],
      "builds_on": ["program-process-thread-basics"],
      "subtopics": ["scheduler", "context switch", "blocking", "ready/running/waiting"],
      "real_work_application": "스레드를 늘렸는데 처리량이 오르지 않는 이유와 latency spike를 설명한다."
    },
    {
      "id": "io-blocking-nonblocking-basics",
      "level": 1,
      "domain": "cs-network-applied",
      "title": "I/O, blocking, non-blocking의 차이",
      "prerequisites": ["program-process-thread-basics"],
      "builds_on": ["program-process-thread-basics"],
      "subtopics": ["I/O wait", "blocking", "non-blocking", "event loop"],
      "real_work_application": "DB/네트워크 호출 지연이 애플리케이션 스레드와 응답 시간에 주는 영향을 설명한다."
    },
    {
      "id": "ip-port-socket-basics",
      "level": 1,
      "domain": "network",
      "title": "IP, 포트, 소켓의 경계",
      "prerequisites": ["program-process-thread-basics"],
      "builds_on": ["program-process-thread-basics"],
      "subtopics": ["IP", "port", "socket", "listen", "connect"],
      "real_work_application": "포트는 열려 있는데 연결이 실패하거나 특정 인터페이스에서만 접속되는 문제를 진단한다."
    },
    {
      "id": "dns-resolution-practical",
      "level": 1,
      "domain": "network",
      "title": "DNS 조회 흐름과 캐시",
      "prerequisites": ["ip-port-socket-basics"],
      "builds_on": ["ip-port-socket-basics"],
      "subtopics": ["domain", "recursive resolver", "authoritative DNS", "TTL", "cache"],
      "real_work_application": "배포 후 일부 사용자만 접속이 안 되는 문제, DNS 변경 전파 지연, 잘못된 레코드 문제를 설명한다."
    },
    {
      "id": "tcp-connection-lifecycle",
      "level": 2,
      "domain": "network",
      "title": "TCP 연결 생명주기",
      "prerequisites": ["ip-port-socket-basics"],
      "builds_on": ["ip-port-socket-basics"],
      "subtopics": ["three-way handshake", "state", "FIN", "RST", "TIME_WAIT"],
      "real_work_application": "connection refused, timeout, reset, TIME_WAIT 증가를 구분해서 장애를 진단한다."
    },
    {
      "id": "timeout-retry-backoff",
      "level": 2,
      "domain": "cs-network-applied",
      "title": "Timeout, retry, backoff의 실무 기준",
      "prerequisites": ["tcp-connection-lifecycle", "io-blocking-nonblocking-basics"],
      "builds_on": ["tcp-connection-lifecycle"],
      "subtopics": ["connect timeout", "read timeout", "retry", "exponential backoff", "idempotency"],
      "real_work_application": "느린 외부 API가 전체 서비스를 멈추지 않게 하고, 재시도가 장애를 증폭시키지 않도록 설계한다."
    },
    {
      "id": "latency-throughput-capacity",
      "level": 2,
      "domain": "cs-network-applied",
      "title": "Latency, throughput, capacity 구분",
      "prerequisites": ["cpu-scheduling-basics", "tcp-connection-lifecycle"],
      "builds_on": ["cpu-scheduling-basics", "tcp-connection-lifecycle"],
      "subtopics": ["latency", "throughput", "queueing", "bottleneck", "saturation"],
      "real_work_application": "응답 시간이 느린 문제와 처리량 한계 문제를 분리해서 병목을 찾는다."
    },
    {
      "id": "queueing-backpressure",
      "level": 3,
      "domain": "cs-network-applied",
      "title": "Queueing과 backpressure",
      "prerequisites": ["latency-throughput-capacity"],
      "builds_on": ["latency-throughput-capacity"],
      "subtopics": ["queue", "backpressure", "load shedding", "head-of-line blocking"],
      "real_work_application": "트래픽 급증 시 큐가 쌓이고 지연이 폭발하는 원인을 설명하고 완화 전략을 고른다."
    },
    {
      "id": "consistency-concurrency-basics",
      "level": 3,
      "domain": "cs",
      "title": "동시성, race condition, consistency 기초",
      "prerequisites": ["program-process-thread-basics", "memory-stack-heap-basics"],
      "builds_on": ["program-process-thread-basics"],
      "subtopics": ["race condition", "critical section", "lock", "atomicity", "visibility"],
      "real_work_application": "동시에 들어온 작업이 같은 데이터를 갱신할 때 발생하는 오류를 설명하고 방어한다."
    }
  ]
}
